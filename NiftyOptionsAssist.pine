//@version=5
indicator("Nifty Options Assist PRO [Claude]", overlay=true, max_bars_back=500, max_lines_count=100, max_boxes_count=100, max_labels_count=100)

// ═══════════════════════════════════════════════════════════════
//   NIFTY OPTIONS ASSIST PRO — Built by Claude
//   Combined: Full Indicator + EMA 50/100/200 + Cross Signals
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────
// SECTION 1: INPUTS
// ─────────────────────────────────────────
g1 = "① VWAP Settings"
show_vwap        = input.bool(true,  "Show VWAP",           group=g1)
show_vwap_bands  = input.bool(true,  "Show VWAP Bands",     group=g1)
vwap_mult1       = input.float(1.0,  "Band 1 Multiplier",   group=g1)
vwap_mult2       = input.float(2.0,  "Band 2 Multiplier",   group=g1)

g2 = "② EMA Settings"
show_ema         = input.bool(true,  "Show EMA",            group=g2)
ema_fast_len     = input.int(9,      "Fast EMA Length",     group=g2)
ema_slow_len     = input.int(21,     "Slow EMA Length",     group=g2)

g2b = "② EMA 50/100/200 Settings"
show_ema_ext     = input.bool(true,  "Show EMA 50/100/200", group=g2b)
ema50Source      = input.source(close, "EMA 50 Source",     group=g2b)
ema50Length      = input.int(50,  minval=1, title="EMA 50 Length",  group=g2b)
ema100Source     = input.source(close, "EMA 100 Source",    group=g2b)
ema100Length     = input.int(100, minval=1, title="EMA 100 Length", group=g2b)
ema200Source     = input.source(close, "EMA 200 Source",    group=g2b)
ema200Length     = input.int(200, minval=1, title="EMA 200 Length", group=g2b)

g3 = "③ Supertrend Settings"
show_st          = input.bool(true,  "Show Supertrend",     group=g3)
st_atr_len       = input.int(10,     "ATR Length",          group=g3)
st_factor        = input.float(3.0,  "Factor",              group=g3)

g4 = "④ RSI Settings"
show_rsi         = input.bool(true,  "Show RSI Levels",     group=g4)
rsi_len          = input.int(14,     "RSI Length",          group=g4)
rsi_ob           = input.int(70,     "Overbought Level",    group=g4)
rsi_os           = input.int(30,     "Oversold Level",      group=g4)

g5 = "⑤ Order Block Settings"
show_ob          = input.bool(true,  "Show Order Blocks",   group=g5)
ob_lookback      = input.int(10,     "OB Lookback Bars",    group=g5, minval=3, maxval=50)

g6 = "⑥ Volume Settings"
show_vol_signal  = input.bool(true,  "Show Volume Signals", group=g6)
vol_mult         = input.float(1.5,  "Spike Multiplier",    group=g6)

g7 = "⑦ ATR SL & Target"
show_sl_tp       = input.bool(true,  "Show SL & Targets",   group=g7)
atr_len          = input.int(14,     "ATR Length",          group=g7)
sl_atr_mult      = input.float(1.0,  "SL = ATR x",         group=g7)
tp1_atr_mult     = input.float(1.5,  "T1 = ATR x",         group=g7)
tp2_atr_mult     = input.float(3.0,  "T2 = ATR x",         group=g7)

g8 = "⑧ Market Structure"
show_structure   = input.bool(true,  "Show HH/HL/LH/LL",   group=g8)
struct_lookback  = input.int(5,      "Pivot Lookback",      group=g8, minval=2, maxval=20)

g9 = "⑨ Signal Settings"
show_signals     = input.bool(true,  "Show Buy/Sell Signals", group=g9)
show_table       = input.bool(true,  "Show Bias Table",     group=g9)


// ─────────────────────────────────────────
// SECTION 2: VWAP + BANDS
// ─────────────────────────────────────────
var float vwap_sum = 0.0
var float vol_sum  = 0.0
var float sq_sum   = 0.0

is_new_day = ta.change(time("D")) != 0
if is_new_day
    vwap_sum := 0.0
    vol_sum  := 0.0
    sq_sum   := 0.0

typical_price = (high + low + close) / 3
vwap_sum     += typical_price * volume
vol_sum      += volume
sq_sum       += typical_price * typical_price * volume

vwap_val    = vwap_sum / vol_sum
variance    = math.max(sq_sum / vol_sum - vwap_val * vwap_val, 0)
std_dev     = math.sqrt(variance)

vwap_upper1 = vwap_val + vwap_mult1 * std_dev
vwap_lower1 = vwap_val - vwap_mult1 * std_dev
vwap_upper2 = vwap_val + vwap_mult2 * std_dev
vwap_lower2 = vwap_val - vwap_mult2 * std_dev

vwap_line = plot(show_vwap ? vwap_val    : na, "VWAP",    color=color.new(color.gray,  0), linewidth=2, style=plot.style_circles)
vwap_u1   = plot(show_vwap_bands ? vwap_upper1 : na, "VB U1", color=color.new(color.red,   50), linewidth=1)
vwap_l1   = plot(show_vwap_bands ? vwap_lower1 : na, "VB L1", color=color.new(color.green, 50), linewidth=1)
vwap_u2   = plot(show_vwap_bands ? vwap_upper2 : na, "VB U2", color=color.new(color.red,   75), linewidth=1)
vwap_l2   = plot(show_vwap_bands ? vwap_lower2 : na, "VB L2", color=color.new(color.green, 75), linewidth=1)

fill(vwap_u1, vwap_u2, color=color.new(color.red,   92))
fill(vwap_l1, vwap_l2, color=color.new(color.green, 92))

if barstate.islast and show_vwap
    label.new(bar_index + 2, vwap_val,
     "VWAP: " + str.tostring(math.round(vwap_val, 2)),
     style=label.style_label_left,
     color=color.new(color.gray, 20),
     textcolor=color.white,
     size=size.small)


// ─────────────────────────────────────────
// SECTION 3: EMA 9 / 21
// ─────────────────────────────────────────
ema_fast     = ta.ema(close, ema_fast_len)
ema_slow     = ta.ema(close, ema_slow_len)
ema_bull     = ema_fast > ema_slow
ema_fast_col = ema_bull ? color.new(color.lime, 0) : color.new(color.red, 0)
ema_slow_col = ema_bull ? color.new(color.green, 40) : color.new(color.red, 40)

plot(show_ema ? ema_fast : na, "EMA 9",  color=ema_fast_col, linewidth=2)
plot(show_ema ? ema_slow : na, "EMA 21", color=ema_slow_col, linewidth=1)

if barstate.islast and show_ema
    label.new(bar_index + 2, ema_fast, "EMA9",  style=label.style_label_left, color=color.lime,  textcolor=color.black, size=size.tiny)
    label.new(bar_index + 2, ema_slow, "EMA21", style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)


// ─────────────────────────────────────────
// SECTION 3B: EMA 50 / 100 / 200
// ─────────────────────────────────────────
ema50  = ta.ema(ema50Source,  ema50Length)
ema100 = ta.ema(ema100Source, ema100Length)
ema200 = ta.ema(ema200Source, ema200Length)

plot(show_ema_ext ? ema50  : na, "EMA 50",  color=color.orange, linewidth=2)
plot(show_ema_ext ? ema100 : na, "EMA 100", color=color.green,  linewidth=2)
plot(show_ema_ext ? ema200 : na, "EMA 200", color=color.red,    linewidth=2)

plot(show_ema_ext and ta.cross(ema50, ema100) ? ema100 : na,
     title="Early Cross", style=plot.style_circles,
     linewidth=4, color=color.new(color.fuchsia, 0))

plot(show_ema_ext and ta.cross(ema50, ema200) ? ema200 : na,
     title="Golden Cross", style=plot.style_circles,
     linewidth=4, color=color.new(color.purple, 0))


// ─────────────────────────────────────────
// SECTION 4: SUPERTREND
// ─────────────────────────────────────────
[st_val, st_dir] = ta.supertrend(st_factor, st_atr_len)
st_bull          = st_dir < 0
st_color         = st_bull ? color.new(color.green, 0) : color.new(color.red, 0)

plot(show_st ? st_val : na, "Supertrend",
     color=st_color, linewidth=2, style=plot.style_linebr)

plotshape(show_st and ta.crossover(close,  st_val), "ST Bull Cross", shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.tiny)
plotshape(show_st and ta.crossunder(close, st_val), "ST Bear Cross", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.tiny)


// ─────────────────────────────────────────
// SECTION 5: RSI
// ─────────────────────────────────────────
rsi_val    = ta.rsi(close, rsi_len)
rsi_ob_hit = rsi_val >= rsi_ob
rsi_os_hit = rsi_val <= rsi_os

bgcolor(show_rsi and rsi_ob_hit ? color.new(color.red,   90) : na, title="RSI Overbought Zone")
bgcolor(show_rsi and rsi_os_hit ? color.new(color.green, 90) : na, title="RSI Oversold Zone")

if barstate.islast and show_rsi
    rsi_txt = "RSI: " + str.tostring(math.round(rsi_val, 1))
    rsi_col = rsi_ob_hit ? color.red : rsi_os_hit ? color.green : color.gray
    label.new(bar_index + 2, high + ta.atr(14) * 2,
     rsi_txt,
     style=label.style_label_left,
     color=color.new(rsi_col, 20),
     textcolor=color.white,
     size=size.small)


// ─────────────────────────────────────────
// SECTION 6: ATR
// ─────────────────────────────────────────
atr_val = ta.atr(atr_len)


// ─────────────────────────────────────────
// SECTION 7: VOLUME SPIKE
// ─────────────────────────────────────────
avg_vol      = ta.sma(volume, 20)
is_vol_spike = volume > avg_vol * vol_mult
vol_bull     = is_vol_spike and close > open
vol_bear     = is_vol_spike and close < open

bgcolor(show_vol_signal and vol_bull ? color.new(color.green, 88) : na, title="Vol Spike Bull")
bgcolor(show_vol_signal and vol_bear ? color.new(color.red,   88) : na, title="Vol Spike Bear")


// ─────────────────────────────────────────
// SECTION 8: ORDER BLOCKS
// ─────────────────────────────────────────
atr14 = ta.atr(14)

is_strong_bull_candle = close > open and (close - open) > atr14 * 0.7
is_strong_bear_candle = open > close and (open - close) > atr14 * 0.7

var float bull_ob_h = na
var float bull_ob_l = na
var float bear_ob_h = na
var float bear_ob_l = na
var int   bull_ob_b = na
var int   bear_ob_b = na

if show_ob and is_strong_bull_candle
    for i = 1 to ob_lookback
        if open[i] > close[i]
            bull_ob_h := high[i]
            bull_ob_l := low[i]
            bull_ob_b := bar_index - i
            break

if show_ob and is_strong_bear_candle
    for i = 1 to ob_lookback
        if close[i] > open[i]
            bear_ob_h := high[i]
            bear_ob_l := low[i]
            bear_ob_b := bar_index - i
            break

if show_ob and not na(bull_ob_b) and bull_ob_b == bar_index - 1
    box.new(bull_ob_b, bull_ob_h, bar_index + 15, bull_ob_l,
     border_color=color.new(color.green, 20),
     bgcolor=color.new(color.green, 82),
     border_width=1,
     text="Bull OB",
     text_color=color.green,
     text_size=size.tiny)

if show_ob and not na(bear_ob_b) and bear_ob_b == bar_index - 1
    box.new(bear_ob_b, bear_ob_h, bar_index + 15, bear_ob_l,
     border_color=color.new(color.red, 20),
     bgcolor=color.new(color.red, 82),
     border_width=1,
     text="Bear OB",
     text_color=color.red,
     text_size=size.tiny)


// ─────────────────────────────────────────
// SECTION 9: MARKET STRUCTURE
// ─────────────────────────────────────────
pivot_high = ta.pivothigh(high, struct_lookback, struct_lookback)
pivot_low  = ta.pivotlow(low,   struct_lookback, struct_lookback)

var float last_ph = na
var float last_pl = na
var float prev_ph = na
var float prev_pl = na

if not na(pivot_high)
    prev_ph := last_ph
    last_ph := pivot_high

if not na(pivot_low)
    prev_pl := last_pl
    last_pl := pivot_low

is_hh = not na(pivot_high) and not na(prev_ph) and pivot_high > prev_ph
is_lh = not na(pivot_high) and not na(prev_ph) and pivot_high < prev_ph
is_hl = not na(pivot_low)  and not na(prev_pl) and pivot_low  > prev_pl
is_ll = not na(pivot_low)  and not na(prev_pl) and pivot_low  < prev_pl

if show_structure
    if is_hh
        label.new(bar_index[struct_lookback], pivot_high, "HH",
         style=label.style_label_down, color=color.new(color.green, 20), textcolor=color.white, size=size.tiny)
    if is_lh
        label.new(bar_index[struct_lookback], pivot_high, "LH",
         style=label.style_label_down, color=color.new(color.red, 20),   textcolor=color.white, size=size.tiny)
    if is_hl
        label.new(bar_index[struct_lookback], pivot_low,  "HL",
         style=label.style_label_up,   color=color.new(color.green, 20), textcolor=color.white, size=size.tiny)
    if is_ll
        label.new(bar_index[struct_lookback], pivot_low,  "LL",
         style=label.style_label_up,   color=color.new(color.red, 20),   textcolor=color.white, size=size.tiny)


// ─────────────────────────────────────────
// SECTION 10: BUY CE / BUY PE SIGNALS
// ─────────────────────────────────────────
above_vwap    = close > vwap_val
below_vwap    = close < vwap_val
ema_cross_up  = ta.crossover(ema_fast,  ema_slow)
ema_cross_dn  = ta.crossunder(ema_fast, ema_slow)
st_cross_bull = ta.crossover(close,  st_val)
st_cross_bear = ta.crossunder(close, st_val)

strong_buy_ce = show_signals and ema_cross_up and above_vwap and st_bull and is_vol_spike and not rsi_ob_hit
strong_buy_pe = show_signals and ema_cross_dn and below_vwap and not st_bull and is_vol_spike and not rsi_os_hit
med_buy_ce    = show_signals and ema_cross_up and above_vwap and st_bull and not strong_buy_ce
med_buy_pe    = show_signals and ema_cross_dn and below_vwap and not st_bull and not strong_buy_pe
vwap_rej_bear = show_signals and high >= vwap_val and close < vwap_val and is_vol_spike and below_vwap
vwap_rej_bull = show_signals and low  <= vwap_val and close > vwap_val and is_vol_spike and above_vwap
st_flip_bull  = show_signals and st_cross_bull and above_vwap
st_flip_bear  = show_signals and st_cross_bear and below_vwap

plotshape(strong_buy_ce, "🔥 STRONG BUY CE", shape.labelup,      location.belowbar, color.new(color.green,  0),  text="BUY CE🔥", textcolor=color.white, size=size.normal)
plotshape(strong_buy_pe, "🔥 STRONG BUY PE", shape.labeldown,    location.abovebar, color.new(color.red,    0),  text="BUY PE🔥", textcolor=color.white, size=size.normal)
plotshape(med_buy_ce,    "⚡ BUY CE",         shape.labelup,      location.belowbar, color.new(color.green,  30), text="CE ⚡",    textcolor=color.white, size=size.small)
plotshape(med_buy_pe,    "⚡ BUY PE",         shape.labeldown,    location.abovebar, color.new(color.red,    30), text="PE ⚡",    textcolor=color.white, size=size.small)
plotshape(vwap_rej_bear, "VWAP Rej ↓",       shape.labeldown,    location.abovebar, color.new(color.orange, 0),  text="VWAP❌",   textcolor=color.white, size=size.small)
plotshape(vwap_rej_bull, "VWAP Bounce ↑",    shape.labelup,      location.belowbar, color.new(color.blue,   0),  text="VWAP✅",   textcolor=color.white, size=size.small)
plotshape(st_flip_bull,  "ST Flip Bull",     shape.triangleup,   location.belowbar, color.new(color.lime,   20), size=size.small)
plotshape(st_flip_bear,  "ST Flip Bear",     shape.triangledown, location.abovebar, color.new(color.maroon, 20), size=size.small)


// ─────────────────────────────────────────
// SECTION 11: ATR SL & TARGET LABELS
// ─────────────────────────────────────────
if show_sl_tp and strong_buy_ce
    sl_price  = close - atr_val * sl_atr_mult
    tp1_price = close + atr_val * tp1_atr_mult
    tp2_price = close + atr_val * tp2_atr_mult
    label.new(bar_index, sl_price,  "SL: "  + str.tostring(math.round(sl_price,  2)), style=label.style_label_right, color=color.new(color.red,   20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp1_price, "T1: "  + str.tostring(math.round(tp1_price, 2)), style=label.style_label_right, color=color.new(color.green, 20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp2_price, "T2: "  + str.tostring(math.round(tp2_price, 2)), style=label.style_label_right, color=color.new(color.teal,  20), textcolor=color.white, size=size.tiny)

if show_sl_tp and strong_buy_pe
    sl_price  = close + atr_val * sl_atr_mult
    tp1_price = close - atr_val * tp1_atr_mult
    tp2_price = close - atr_val * tp2_atr_mult
    label.new(bar_index, sl_price,  "SL: "  + str.tostring(math.round(sl_price,  2)), style=label.style_label_right, color=color.new(color.red,   20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp1_price, "T1: "  + str.tostring(math.round(tp1_price, 2)), style=label.style_label_right, color=color.new(color.green, 20), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp2_price, "T2: "  + str.tostring(math.round(tp2_price, 2)), style=label.style_label_right, color=color.new(color.teal,  20), textcolor=color.white, size=size.tiny)


// ─────────────────────────────────────────
// SECTION 12: BIAS TABLE
// ─────────────────────────────────────────
var table t = table.new(position.top_right, 2, 10,
 border_color=color.new(color.gray, 40),
 border_width=1,
 bgcolor=color.new(color.black, 65))

if barstate.islast and show_table
    table.cell(t, 0, 0, "INDICATOR", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20))
    table.cell(t, 1, 0, "STATUS",    text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20))

    vb = close > vwap_val
    table.cell(t, 0, 1, "VWAP",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, vb ? "▲ BULL" : "▼ BEAR", text_color=color.white, text_size=size.small, bgcolor=vb ? color.new(color.green,50) : color.new(color.red,50))

    eb = ema_fast > ema_slow
    table.cell(t, 0, 2, "EMA 9/21", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, eb ? "▲ BULL" : "▼ BEAR", text_color=color.white, text_size=size.small, bgcolor=eb ? color.new(color.green,50) : color.new(color.red,50))

    table.cell(t, 0, 3, "Supertrend", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, st_bull ? "▲ BULL" : "▼ BEAR", text_color=color.white, text_size=size.small, bgcolor=st_bull ? color.new(color.green,50) : color.new(color.red,50))

    rsi_status = rsi_ob_hit ? "⚠ OVERBOUGHT" : rsi_os_hit ? "⚠ OVERSOLD" : "✓ NEUTRAL"
    rsi_col    = rsi_ob_hit ? color.new(color.red,40) : rsi_os_hit ? color.new(color.green,40) : color.new(color.gray,50)
    table.cell(t, 0, 4, "RSI " + str.tostring(math.round(rsi_val,1)), text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, rsi_status, text_color=color.white, text_size=size.small, bgcolor=rsi_col)

    vs = is_vol_spike
    table.cell(t, 0, 5, "VOLUME",    text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, vs ? "🔥 SPIKE" : "— normal", text_color=color.white, text_size=size.small, bgcolor=vs ? color.new(color.orange,40) : color.new(color.gray,60))

    struct_bias = (is_hh or is_hl) ? "▲ BULLISH" : (is_ll or is_lh) ? "▼ BEARISH" : "→ NEUTRAL"
    struct_col  = (is_hh or is_hl) ? color.new(color.green,50) : (is_ll or is_lh) ? color.new(color.red,50) : color.new(color.gray,50)
    table.cell(t, 0, 6, "STRUCTURE", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, struct_bias, text_color=color.white, text_size=size.small, bgcolor=struct_col)

    table.cell(t, 0, 7, "ATR",       text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 7, str.tostring(math.round(atr_val, 2)), text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.gray,60))

    table.cell(t, 0, 8, "VWAP Val",  text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 8, str.tostring(math.round(vwap_val, 2)), text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.gray,60))

    bull_score = (vb ? 1 : 0) + (eb ? 1 : 0) + (st_bull ? 1 : 0) + (not rsi_ob_hit ? 1 : 0)
    overall    = bull_score >= 4 ? "🟢 STRONG BUY CE" :
                 bull_score == 3 ? "🟢 BUY CE" :
                 bull_score == 2 ? "⚪ WAIT" :
                 bull_score == 1 ? "🔴 BUY PE" :
                                   "🔴 STRONG BUY PE"
    ovr_col    = bull_score >= 3 ? color.new(color.green,30) :
                 bull_score == 2 ? color.new(color.gray, 40) :
                                   color.new(color.red,  30)
    table.cell(t, 0, 9, "BIAS",    text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy,20))
    table.cell(t, 1, 9, overall,   text_color=color.white, text_size=size.small, bgcolor=ovr_col)


// ─────────────────────────────────────────
// SECTION 13: ALERTS
// ─────────────────────────────────────────
alertcondition(strong_buy_ce,  "🔥 STRONG BUY CE",      "STRONG BUY CE SIGNAL — All confluences aligned!")
alertcondition(strong_buy_pe,  "🔥 STRONG BUY PE",      "STRONG BUY PE SIGNAL — All confluences aligned!")
alertcondition(med_buy_ce,     "⚡ BUY CE Signal",       "BUY CE — Medium strength signal. Check chart.")
alertcondition(med_buy_pe,     "⚡ BUY PE Signal",       "BUY PE — Medium strength signal. Check chart.")
alertcondition(vwap_rej_bear,  "VWAP Rejection Bear",   "VWAP Rejection Bearish — BUY PE setup!")
alertcondition(vwap_rej_bull,  "VWAP Bounce Bull",      "VWAP Bounce Bullish — BUY CE setup!")
alertcondition(st_flip_bull,   "Supertrend Flip Bull",  "Supertrend flipped BULLISH above VWAP!")
alertcondition(st_flip_bear,   "Supertrend Flip Bear",  "Supertrend flipped BEARISH below VWAP!")
